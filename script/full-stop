#!/usr/bin/env bash

set -eu
set -o pipefail

export DOTFILES_DIR="$HOME/.dotfiles"
export FULL_STOP_DIR="$DOTFILES_DIR/full-stop"

# --- Globals ---
ACTION="install"
DRY_RUN=false
FORCE=false
DO_BREW=true
DO_PULL=true
BREW_EXPLICIT=false
SELECTED_TOPICS=()
EXCLUDED_DIRS=("full-stop" "bin")
FULL_STOP_ARGS=("$@")
PLATFORM="$(uname -s)"
PLATFORM_LOWER="$(echo "$PLATFORM" | tr '[:upper:]' '[:lower:]')"

# Counters for summary
COUNT_LINKS=0
COUNT_SKIPPED=0
COUNT_TOPICS_PROCESSED=0

# --- Output helpers ---

info () {
  printf "\r  [ \033[00;34m..\033[0m ] %s\n" "$1"
}

user () {
  printf "\r  [ \033[0;33m??\033[0m ] %s\n" "$1"
}

success () {
  printf "\r\033[2K  [ \033[00;32mOK\033[0m ] %s\n" "$1"
}

fail () {
  printf "\r\033[2K  [\033[0;31mFAIL\033[0m] %s\n" "$1"
  echo ''
  exit
}

plan () {
  printf "\r  [ \033[00;36m~~\033[0m ] %s\n" "$1"
}

warn () {
  printf "\r  [ \033[0;33m!!\033[0m ] %s\n" "$1"
}

phase () {
  printf "\n\033[1;37m── %s ──\033[0m\n\n" "$1"
}

topic_header () {
  printf "    \033[1m%s\033[0m\n" "$1"
}

# --- Shared helpers ---

show_help () {
  echo "Usage: full-stop [OPTIONS] [TOPIC ...]"
  echo ""
  echo "Options:"
  echo "  --dry-run, --plan   Show what would happen without making changes"
  echo "  --unlink            Remove symlinks managed by full-stop"
  echo "  --status            Show health of all managed symlinks"
  echo "  --force             Overwrite existing files without prompting"
  echo "  --no-brew           Skip homebrew update and bundle"
  echo "  --with-brew         Force homebrew even with topic selection"
  echo "  --no-pull           Skip git pull and submodule update"
  echo "  --no-update         Skip git pull, brew update, and brew bundle (fast/offline)"
  echo "  --list-topics       List available topics and exit"
  echo "  --help, -h          Show this help"
  echo ""
  echo "Examples:"
  echo "  full-stop                         # full run"
  echo "  full-stop git fish                # only process git and fish topics"
  echo "  full-stop --dry-run               # preview what would happen"
  echo "  full-stop --force ghostty         # overwrite existing files (no prompts)"
  echo "  full-stop --no-update             # skip pull and brew (fast re-link)"
  echo "  full-stop --unlink                # remove all managed symlinks"
  echo "  full-stop --unlink git            # remove only git topic symlinks"
  echo "  full-stop --unlink --dry-run      # preview what would be unlinked"
  echo "  full-stop --status                # check symlink health"
  echo "  full-stop --status git            # check only git topic"
}

get_all_topics () {
  local topics=()
  for dir in "$DOTFILES_DIR"/*/; do
    local name
    name="$(basename "$dir")"
    local excluded=false
    for ex in "${EXCLUDED_DIRS[@]}"; do
      if [ "$name" = "$ex" ]; then
        excluded=true
        break
      fi
    done
    if [ "$excluded" = "false" ]; then
      topics+=("$name")
    fi
  done
  printf '%s\n' "${topics[@]}"
}

validate_topic () {
  local topic="$1"
  for ex in "${EXCLUDED_DIRS[@]}"; do
    if [ "$topic" = "$ex" ]; then
      fail "'$topic' is not a valid topic (it is part of the framework)"
    fi
  done
  if ! [ -d "$DOTFILES_DIR/$topic" ]; then
    fail "topic '$topic' does not exist in $DOTFILES_DIR"
  fi
}

list_topics () {
  info "Available topics:"
  while IFS= read -r t; do
    local badges=""
    [ -f "$DOTFILES_DIR/$t/setup.sh" ] && badges+=" [setup.sh]"
    [ -f "$DOTFILES_DIR/$t/setup.darwin.sh" ] && badges+=" [setup.darwin.sh]"
    [ -f "$DOTFILES_DIR/$t/setup.linux.sh" ] && badges+=" [setup.linux.sh]"
    [ -f "$DOTFILES_DIR/$t/teardown.sh" ] && badges+=" [teardown.sh]"
    [ -f "$DOTFILES_DIR/$t/teardown.darwin.sh" ] && badges+=" [teardown.darwin.sh]"
    [ -f "$DOTFILES_DIR/$t/teardown.linux.sh" ] && badges+=" [teardown.linux.sh]"
    local symcount
    symcount=$(find -H "$DOTFILES_DIR/$t" -name '*.symlink' 2>/dev/null | wc -l | tr -d ' ')
    [ "$symcount" -gt 0 ] && badges+=" [${symcount} symlinks]"
    local linktocount
    linktocount=$(find -H "$DOTFILES_DIR/$t" -name '*.linkto' 2>/dev/null | wc -l | tr -d ' ')
    [ "$linktocount" -gt 0 ] && badges+=" [${linktocount} linkto]"
    echo "  $t${badges}"
  done < <(get_all_topics)
}

# Returns search directories based on SELECTED_TOPICS
get_search_dirs () {
  if [[ ${#SELECTED_TOPICS[@]} -gt 0 ]]; then
    for topic in "${SELECTED_TOPICS[@]}"; do
      echo "$DOTFILES_DIR/$topic"
    done
  else
    echo "$DOTFILES_DIR"
  fi
}

# Find *.symlink files at the right depth, respecting topic filtering
# Output is sorted for deterministic topic grouping
find_symlink_files () {
  local depth_type="$1"
  while IFS= read -r search_dir; do
    local d
    if [ "$search_dir" = "$DOTFILES_DIR" ]; then
      d=$([[ "$depth_type" == "shallow" ]] && echo "2" || echo "3")
    else
      d=$([[ "$depth_type" == "shallow" ]] && echo "1" || echo "2")
    fi
    find -H "$search_dir" -mindepth "$d" -maxdepth "$d" -name '*.symlink' -not -path '*.git*'
  done < <(get_search_dirs) | sort
}

# Find *.linkto files, respecting topic filtering
find_linkto_files () {
  while IFS= read -r search_dir; do
    find -H "$search_dir" -name '*.linkto' -not -path '*.git*' -print0
  done < <(get_search_dirs)
}

# Find setup.sh or teardown.sh files, respecting topic filtering
find_topic_scripts () {
  local script_name="$1"
  while IFS= read -r search_dir; do
    if [ "$search_dir" = "$DOTFILES_DIR" ]; then
      find -H "$search_dir" -mindepth 2 -maxdepth 2 -name "$script_name" -not -path '*.git*'
    else
      find -H "$search_dir" -mindepth 1 -maxdepth 1 -name "$script_name" -not -path '*.git*'
    fi
  done < <(get_search_dirs)
}

# --- Argument parsing ---

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run|--plan)
      DRY_RUN=true
      ;;
    --unlink)
      ACTION="unlink"
      ;;
    --status)
      ACTION="status"
      ;;
    --force)
      FORCE=true
      ;;
    --no-brew)
      DO_BREW=false
      BREW_EXPLICIT=true
      ;;
    --with-brew)
      DO_BREW=true
      BREW_EXPLICIT=true
      ;;
    --no-pull)
      DO_PULL=false
      ;;
    --no-update)
      DO_PULL=false
      DO_BREW=false
      ;;
    --list-topics)
      list_topics
      exit 0
      ;;
    --help|-h)
      show_help
      exit 0
      ;;
    -*)
      fail "unknown option: $1"
      ;;
    *)
      SELECTED_TOPICS+=("$1")
      ;;
  esac
  shift
done

# When topics are specified, skip brew and pull by default
if [[ ${#SELECTED_TOPICS[@]} -gt 0 && "$BREW_EXPLICIT" == "false" ]]; then
  DO_BREW=false
  DO_PULL=false
fi

# Validate selected topics
for t in "${SELECTED_TOPICS[@]}"; do
  validate_topic "$t"
done

echo ''

if [[ "$DRY_RUN" == "true" ]]; then
  plan "DRY RUN — showing what would happen without making changes"
  echo ''
fi

# --- Logging ---
FULL_STOP_LOG="${FULL_STOP_LOG:-$HOME/.full-stop.log}"

_strip_ansi () {
  perl -pe 's/\e\[[0-9;]*[a-zA-Z]//g; s/\r//g'
}

{
  echo "=== full-stop $(date '+%Y-%m-%d %H:%M:%S') ==="
  if [[ ${#FULL_STOP_ARGS[@]} -gt 0 ]]; then
    echo "  args: ${FULL_STOP_ARGS[*]}"
  else
    echo "  args: (none)"
  fi
  [[ "$DRY_RUN" == "true" ]] && echo "  mode: DRY RUN"
  echo "  platform: $PLATFORM"
} >> "$FULL_STOP_LOG"

exec > >( tee >( _strip_ansi >> "$FULL_STOP_LOG" ) ) 2>&1

# --- Core functions ---

check_dotfiles_dir () {
  local current_dir
  current_dir="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

  if ! [ -d "$DOTFILES_DIR" ]; then
    fail "expected to find a $DOTFILES_DIR directory"
  fi

  if [ "$FULL_STOP_DIR/script" != "$current_dir" ]; then
    fail "your dotfiles must go in $DOTFILES_DIR, and Full Stop in $FULL_STOP_DIR"
  fi
}

update_dotfiles_dir () {
  if [[ "$DRY_RUN" == "true" ]]; then
    plan "would git pull --rebase in $DOTFILES_DIR"
    plan "would git submodule update --init in $DOTFILES_DIR"
    return
  fi
  info "updating $DOTFILES_DIR"
  ( cd "$DOTFILES_DIR" && git pull --rebase )
  info "updating submodules"
  ( cd "$DOTFILES_DIR" && git submodule update --init )
}

install_and_update_homebrew () {
  if [[ "$DRY_RUN" == "true" ]]; then
    if ! command -v brew &>/dev/null; then
      plan "would install Homebrew (not currently installed)"
    else
      plan "Homebrew already installed"
    fi
    plan "would run: brew update"
    return
  fi
  "$FULL_STOP_DIR/homebrew/setup.sh"
  info 'brew update'
  brew update
}

install_brew_packages () {
  if [ -f "$DOTFILES_DIR/Brewfile" ]; then
    if [[ "$DRY_RUN" == "true" ]]; then
      local count
      count=$(grep -cve '^\s*#' -e '^\s*$' "$DOTFILES_DIR/Brewfile" || true)
      plan "would run: brew bundle ($count entries in Brewfile)"
      return
    fi
    info 'brew bundle'
    ( cd "$DOTFILES_DIR" && brew bundle )
  else
    info 'Brewfile not found'
  fi
}

link_file () {
  local src="$1" dst="$2"

  if [[ "$DRY_RUN" == "true" ]]; then
    if [ -L "$dst" ]; then
      local currentSrc
      currentSrc="$(readlink "$dst")"
      if [ "$currentSrc" == "$src" ]; then
        plan "ok: $dst -> $src (already linked)"
        COUNT_LINKS=$((COUNT_LINKS + 1))
      else
        plan "CONFLICT: $dst exists, points to $currentSrc (would link to $src)"
      fi
    elif [ -f "$dst" ]; then
      plan "CONFLICT: $dst exists as a regular file (would link to $src)"
    elif [ -d "$dst" ]; then
      plan "CONFLICT: $dst exists as a directory (would link to $src)"
    else
      plan "would link: $dst -> $src"
      COUNT_LINKS=$((COUNT_LINKS + 1))
    fi
    return
  fi

  local overwrite= backup= skip=
  local action=

  if [ -f "$dst" ] || [ -d "$dst" ] || [ -L "$dst" ]; then

    if [ "$overwrite_all" == "false" ] && [ "$backup_all" == "false" ] && [ "$skip_all" == "false" ]; then

      local currentSrc
      currentSrc="$(readlink "$dst")"

      if [ "$currentSrc" == "$src" ]; then

        skip=true;

      else

        user "File already exists: $dst ($(basename "$src")), what do you want to do?\n\
        [s]kip, [S]kip all, [o]verwrite, [O]verwrite all, [b]ackup, [B]ackup all?"
        read -r -n 1 action

        case "$action" in
          o )
            overwrite=true;;
          O )
            overwrite_all=true;;
          b )
            backup=true;;
          B )
            backup_all=true;;
          s )
            skip=true;;
          S )
            skip_all=true;;
          * )
            ;;
        esac

      fi

    fi

    overwrite=${overwrite:-$overwrite_all}
    backup=${backup:-$backup_all}
    skip=${skip:-$skip_all}

    if [ "$overwrite" == "true" ]; then
      rm -rf "$dst"
      success "removed $dst"
    fi

    if [ "$backup" == "true" ]; then
      mv "$dst" "${dst}.backup"
      success "moved $dst to ${dst}.backup"
    fi

    if [ "$skip" == "true" ]; then
      success "skipped $src"
      COUNT_SKIPPED=$((COUNT_SKIPPED + 1))
    fi
  fi

  if [ "$skip" != "true" ]; then  # "false" or empty
    ln -s "$1" "$2"
    success "linked $1 to $2"
    COUNT_LINKS=$((COUNT_LINKS + 1))
  fi
}

unlink_file () {
  local src="$1" dst="$2"

  if [ ! -L "$dst" ]; then
    if [ -e "$dst" ]; then
      info "not a symlink, skipping: $dst"
    fi
    return
  fi

  local current_target
  current_target="$(readlink "$dst")"

  if [ "$current_target" != "$src" ]; then
    info "symlink does not point to dotfiles, skipping: $dst -> $current_target"
    return
  fi

  if [[ "$DRY_RUN" == "true" ]]; then
    plan "would unlink: $dst -> $src"
    if [ -e "${dst}.backup" ]; then
      plan "would restore: ${dst}.backup -> $dst"
    fi
    COUNT_LINKS=$((COUNT_LINKS + 1))
    return
  fi

  rm "$dst"
  success "unlinked $dst (was -> $src)"
  COUNT_LINKS=$((COUNT_LINKS + 1))

  if [ -e "${dst}.backup" ]; then
    mv "${dst}.backup" "$dst"
    success "restored ${dst}.backup to $dst"
  fi
}

install_dotfiles () {
  local overwrite_all=$FORCE backup_all=false skip_all=false
  local current_topic=""

  while IFS= read -r src; do
    [ -z "$src" ] && continue
    local topic_name
    topic_name="$(basename "$(dirname "$src")")"
    if [[ "$topic_name" != "$current_topic" ]]; then
      current_topic="$topic_name"
      topic_header "$current_topic"
      COUNT_TOPICS_PROCESSED=$((COUNT_TOPICS_PROCESSED + 1))
    fi

    local path_without_symlink_suffix="${src%.*}"
    local dst="$HOME/.$(basename "$path_without_symlink_suffix")"
    link_file "$src" "$dst"
  done < <(find_symlink_files "shallow")

  while IFS= read -r src; do
    [ -z "$src" ] && continue
    local topic_name
    topic_name="$(echo "$src" | sed "s|$DOTFILES_DIR/||" | cut -d/ -f1)"
    if [[ "$topic_name" != "$current_topic" ]]; then
      current_topic="$topic_name"
      topic_header "$current_topic"
      COUNT_TOPICS_PROCESSED=$((COUNT_TOPICS_PROCESSED + 1))
    fi

    local path_without_symlink_suffix="${src%.*}"
    local file_name
    file_name="$(basename "$path_without_symlink_suffix")"
    local dir_name
    dir_name="$(basename "$(dirname "$path_without_symlink_suffix")")"
    local dst_dir="$HOME/.$dir_name"

    if [[ "$DRY_RUN" == "true" ]]; then
      if [ ! -d "$dst_dir" ]; then
        plan "would create directory: $dst_dir"
      fi
    else
      mkdir "$dst_dir" 2>/dev/null || true
    fi
    link_file "$src" "$dst_dir/$file_name"
  done < <(find_symlink_files "nested")
}

uninstall_dotfiles () {
  while IFS= read -r src; do
    [ -z "$src" ] && continue
    local path_without_symlink_suffix="${src%.*}"
    local dst="$HOME/.$(basename "$path_without_symlink_suffix")"
    unlink_file "$src" "$dst"
  done < <(find_symlink_files "shallow")

  while IFS= read -r src; do
    [ -z "$src" ] && continue
    local path_without_symlink_suffix="${src%.*}"
    local file_name
    file_name="$(basename "$path_without_symlink_suffix")"
    local dir_name
    dir_name="$(basename "$(dirname "$path_without_symlink_suffix")")"
    local dst_dir="$HOME/.$dir_name"
    unlink_file "$src" "$dst_dir/$file_name"

    # Clean up empty parent directories
    if [ -d "$dst_dir" ] && [ -z "$(ls -A "$dst_dir")" ]; then
      if [[ "$DRY_RUN" == "true" ]]; then
        plan "would remove empty directory: $dst_dir"
      else
        rmdir "$dst_dir"
        success "removed empty directory $dst_dir"
      fi
    fi
  done < <(find_symlink_files "nested")
}

install_linkto_files () {
  local found_any=false
  local overwrite_all=$FORCE backup_all=false skip_all=false

  while IFS= read -r -d '' linkto_file; do
    if [ "$found_any" = "false" ]; then
      found_any=true
    fi

    local dst
    dst="$(head -n 1 "$linkto_file")"
    [[ -z "$dst" || "$dst" == \#* ]] && continue
    dst="${dst/#\~/$HOME}"

    local src="${linkto_file%.linkto}"

    if ! [ -e "$src" ] && ! [ -d "$src" ]; then
      fail "linkto source missing: $src (referenced by $linkto_file)"
    fi

    local dst_dir
    dst_dir="$(dirname "$dst")"
    if ! [ -d "$dst_dir" ]; then
      if [[ "$DRY_RUN" == "true" ]]; then
        plan "would create directory: $dst_dir"
      else
        mkdir -p "$dst_dir"
        success "created directory $dst_dir"
      fi
    fi

    link_file "$src" "$dst"
  done < <(find_linkto_files)
}

uninstall_linkto_files () {
  while IFS= read -r -d '' linkto_file; do
    local dst
    dst="$(head -n 1 "$linkto_file")"
    [[ -z "$dst" || "$dst" == \#* ]] && continue
    dst="${dst/#\~/$HOME}"

    local src="${linkto_file%.linkto}"
    unlink_file "$src" "$dst"
  done < <(find_linkto_files)
}

run_topic_installers () {
  local other_platform
  [[ "$PLATFORM_LOWER" == "darwin" ]] && other_platform="linux" || other_platform="darwin"

  if [[ "$DRY_RUN" == "true" ]]; then
    local found=false
    while IFS= read -r installer; do
      [ -z "$installer" ] && continue
      if [ "$found" = "false" ]; then
        found=true
        plan "topic installers that would run:"
      fi
      plan "  $installer"
    done < <(find_topic_scripts "setup.sh")
    while IFS= read -r installer; do
      [ -z "$installer" ] && continue
      if [ "$found" = "false" ]; then
        found=true
        plan "topic installers that would run:"
      fi
      plan "  $installer ($PLATFORM_LOWER)"
    done < <(find_topic_scripts "setup.${PLATFORM_LOWER}.sh")
    while IFS= read -r installer; do
      [ -z "$installer" ] && continue
      plan "  skip: $installer ($other_platform, this is $PLATFORM_LOWER)"
    done < <(find_topic_scripts "setup.${other_platform}.sh")
    if [ "$found" = "false" ]; then
      plan "no topic installers found"
    fi
    return
  fi

  while IFS= read -r installer; do
    [ -z "$installer" ] && continue
    info "sh -c $installer"
    sh -c "$installer"
  done < <(find_topic_scripts "setup.sh")
  while IFS= read -r installer; do
    [ -z "$installer" ] && continue
    info "sh -c $installer ($PLATFORM_LOWER)"
    sh -c "$installer"
  done < <(find_topic_scripts "setup.${PLATFORM_LOWER}.sh")
}

run_topic_teardowns () {
  local other_platform
  [[ "$PLATFORM_LOWER" == "darwin" ]] && other_platform="linux" || other_platform="darwin"

  if [[ "$DRY_RUN" == "true" ]]; then
    while IFS= read -r teardown; do
      [ -z "$teardown" ] && continue
      plan "would run teardown: $teardown ($PLATFORM_LOWER)"
    done < <(find_topic_scripts "teardown.${PLATFORM_LOWER}.sh")
    while IFS= read -r teardown; do
      [ -z "$teardown" ] && continue
      plan "  skip: $teardown ($other_platform, this is $PLATFORM_LOWER)"
    done < <(find_topic_scripts "teardown.${other_platform}.sh")
    while IFS= read -r teardown; do
      [ -z "$teardown" ] && continue
      plan "would run teardown: $teardown"
    done < <(find_topic_scripts "teardown.sh")
    return
  fi

  while IFS= read -r teardown; do
    [ -z "$teardown" ] && continue
    info "sh -c $teardown ($PLATFORM_LOWER)"
    sh -c "$teardown"
  done < <(find_topic_scripts "teardown.${PLATFORM_LOWER}.sh")
  while IFS= read -r teardown; do
    [ -z "$teardown" ] && continue
    info "sh -c $teardown"
    sh -c "$teardown"
  done < <(find_topic_scripts "teardown.sh")
}

# --- Status command ---

status_dotfiles () {
  local count_active=0
  local count_broken=0
  local count_missing=0
  local count_conflict=0

  _check_link () {
    local src="$1" dst="$2"

    if [ -L "$dst" ]; then
      local current_target
      current_target="$(readlink "$dst")"
      if [ "$current_target" = "$src" ]; then
        if [ -e "$dst" ]; then
          success "$dst -> $src"
          count_active=$((count_active + 1))
        else
          warn "$dst -> $src (broken: target missing from disk)"
          count_broken=$((count_broken + 1))
        fi
      else
        warn "$dst points to $current_target (expected $src)"
        count_conflict=$((count_conflict + 1))
      fi
    elif [ -e "$dst" ]; then
      warn "$dst exists but is not a symlink (expected -> $src)"
      if [ -f "$dst" ] && [ -f "$src" ]; then
        if command -v colordiff &>/dev/null; then
          colordiff -u "$src" "$dst" || true
        else
          diff -u "$src" "$dst" || true
        fi
      fi
      count_conflict=$((count_conflict + 1))
    else
      info "$dst is missing (source: $src)"
      count_missing=$((count_missing + 1))
    fi
  }

  info "Checking symlink status ($PLATFORM_LOWER)..."
  echo ''

  while IFS= read -r src; do
    [ -z "$src" ] && continue
    local path_without_suffix="${src%.*}"
    local dst="$HOME/.$(basename "$path_without_suffix")"
    _check_link "$src" "$dst"
  done < <(find_symlink_files "shallow")

  while IFS= read -r src; do
    [ -z "$src" ] && continue
    local path_without_suffix="${src%.*}"
    local file_name
    file_name="$(basename "$path_without_suffix")"
    local dir_name
    dir_name="$(basename "$(dirname "$path_without_suffix")")"
    _check_link "$src" "$HOME/.$dir_name/$file_name"
  done < <(find_symlink_files "nested")

  while IFS= read -r -d '' linkto_file; do
    local dst
    dst="$(head -n 1 "$linkto_file")"
    [[ -z "$dst" || "$dst" == \#* ]] && continue
    dst="${dst/#\~/$HOME}"
    local src="${linkto_file%.linkto}"
    _check_link "$src" "$dst"
  done < <(find_linkto_files)

  echo ''
  local total=$((count_active + count_broken + count_missing + count_conflict))
  info "Status: $total symlinks total"
  [ "$count_active"   -gt 0 ] && success "  $count_active active"
  [ "$count_broken"   -gt 0 ] && warn    "  $count_broken broken"
  [ "$count_missing"  -gt 0 ] && info    "  $count_missing missing"
  [ "$count_conflict" -gt 0 ] && warn    "  $count_conflict conflict"

  if [ "$count_active" -eq "$total" ] && [ "$total" -gt 0 ]; then
    echo ''
    success "All symlinks are healthy"
  fi

  if [ "$count_broken" -gt 0 ] || [ "$count_missing" -gt 0 ] || [ "$count_conflict" -gt 0 ]; then
    exit 1
  fi
}

# --- Main execution ---

check_dotfiles_dir

if [[ "$ACTION" == "unlink" ]]; then
  phase "Teardown"
  run_topic_teardowns
  phase "Unlink Symlinks"
  uninstall_dotfiles
  phase "Unlink Linkto Files"
  uninstall_linkto_files
  phase "Done"
  if [[ "$DRY_RUN" == "true" ]]; then
    plan "DRY RUN complete — no changes were made"
    plan "$COUNT_LINKS symlinks would be removed"
  else
    success "Full Stop unlink complete"
    info "$COUNT_LINKS symlinks removed"
  fi
elif [[ "$ACTION" == "status" ]]; then
  status_dotfiles
else
  if [[ "$DO_PULL" == "true" ]]; then
    phase "Git Pull"
    update_dotfiles_dir
  fi
  if [[ "$DO_BREW" == "true" ]]; then
    phase "Homebrew"
    install_and_update_homebrew
    install_brew_packages
  fi
  phase "Topic Installers"
  run_topic_installers
  phase "Symlinks"
  install_dotfiles
  phase "Linkto Files"
  install_linkto_files
  phase "Done"
  if [[ "$DRY_RUN" == "true" ]]; then
    plan "DRY RUN complete — no changes were made"
    plan "$COUNT_LINKS symlinks would be created/verified, $COUNT_SKIPPED skipped"
  else
    if [[ ${#SELECTED_TOPICS[@]} -gt 0 ]]; then
      success "Full Stop complete (topics: ${SELECTED_TOPICS[*]})"
    else
      success "Full Stop complete"
    fi
    info "$COUNT_LINKS symlinks processed, $COUNT_SKIPPED skipped, $COUNT_TOPICS_PROCESSED topics"
  fi
fi
